---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/format";

interface Props {
  collection: CollectionEntry<"collections">;
  trackCount: number;
  index: number;
}

const { collection, trackCount, index } = Astro.props;
const { data } = collection;
const style = `--card-accent:${data.theme.accent};--card-surface:${data.theme.surface};--card-atmosphere:${data.theme.atmosphere};--card-index:${index}`;
---

<a class="collection-card" href={withBase(`/collections/${data.slug}/`)} style={style}>
  <span class="collection-card__field" aria-hidden="true"></span>
  <span class="collection-card__kind">{data.kind}</span>
  <span class="collection-card__content">
    <strong>{data.title}</strong>
    <span>{data.tagline}</span>
  </span>
  <span class="collection-card__meta">
    {trackCount} {trackCount === 1 ? "track" : "tracks"}
    <span aria-hidden="true">→</span>
  </span>
</a>
